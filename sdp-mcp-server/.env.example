# =============================================================================
# SDP MCP Server — Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# =============================================================================

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Security (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=replace-with-32-character-hex-key-here
JWT_SECRET=replace-with-random-jwt-secret-here
SESSION_SECRET=replace-with-random-session-secret-here

# Database Configuration (future multi-tenant support)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=sdp_mcp
DB_USER=sdpmcpservice
DB_PASSWORD=replace-with-secure-db-password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis Configuration (future multi-tenant support)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=replace-with-secure-redis-password
REDIS_TLS=false
REDIS_DB=0

# Service Desk Plus API Settings
SDP_API_VERSION=v3
SDP_DEFAULT_PAGE_SIZE=100
SDP_MAX_PAGE_SIZE=500
SDP_TIMEOUT_MS=30000
SDP_RETRY_ATTEMPTS=3
SDP_RETRY_DELAY_MS=1000

# Service Desk Plus Instance Configuration
# Base URL for your SDP Cloud instance (custom domain or default)
SDP_BASE_URL=https://sc.burtonmi.gov
# Instance name from your URL: https://sc.burtonmi.gov/app/{SDP_INSTANCE_NAME}/api/v3/
SDP_INSTANCE_NAME=766116682
# Your Zoho portal name
SDP_PORTAL_NAME=burtonmi
# Data center: US, EU, IN, AU, JP, CA, CN, UK
SDP_DATA_CENTER=US

# OAuth Configuration (from Zoho API Console > Self Client)
# Get these by creating a self-client at https://api-console.zoho.com/
SDP_CLIENT_ID=your-client-id-from-self-client
SDP_CLIENT_SECRET=your-client-secret-from-self-client
# Get refresh token by running: node scripts/exchange-code.js
SDP_OAUTH_REFRESH_TOKEN=your-permanent-refresh-token

# SSE Server Configuration
SDP_HTTP_PORT=3456
SDP_HTTP_HOST=0.0.0.0

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_PER_TENANT=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs/sdp-mcp.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
LOG_COMPRESS=true

# Monitoring (future)
METRICS_ENABLED=false
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL_MS=30000
ENABLE_TRACING=false
TRACING_ENDPOINT=http://localhost:4318

# Multi-Tenant Configuration (future)
MAX_TENANTS=100
TENANT_CACHE_TTL_SECONDS=300
TOKEN_REFRESH_BUFFER_SECONDS=300
SCOPE_VALIDATION_ENABLED=true

# Admin Interface (future)
ADMIN_API_ENABLED=false
ADMIN_API_KEY=replace-with-secure-admin-key
ADMIN_PORT=3001

# Development Settings
DEBUG=false
ENABLE_SWAGGER=false
ENABLE_PLAYGROUND=false

# Mock API (for testing without hitting real SDP)
SDP_USE_MOCK_API=false
# SDP_BASE_URL=http://localhost:3457  # Uncomment to use mock server
