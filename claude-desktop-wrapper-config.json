{
  "mcpServers": {
    "service-desk-plus": {
      "command": "node",
      "args": [
        "/path/to/remote-stdio-wrapper.js"
      ],
      "env": {
        "REMOTE_HOST": "YOUR-SERVER-IP",
        "REMOTE_PORT": "3456",
        "SDP_CLIENT_ID": "your-client-id-from-zoho-console",
        "SDP_CLIENT_SECRET": "your-client-secret-from-zoho-console"
      }
    }
  }
}
